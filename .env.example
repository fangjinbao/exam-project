# 用法：cp .env.example .env，然后填好下面每一项（等号后面填你自己的值）。

# MySQL 的 root 账号密码，随便设一个强密码（字母+数字，别加特殊符号）
MYSQL_ROOT_PASSWORD=
# 应用连接数据库用的密码，再设一个强密码（和上面那个不要一样）
MYSQL_PASSWORD=
# Redis 密码，设一个强密码，不能留空
REDIS_PASSWORD=
# 登录令牌加密密钥，运行 openssl rand -hex 32 生成一串贴进来
JWT_SECRET=

# ================== 下面一般不用改 ==================
# 数据库名和账号，保持 agentpm 即可（改了后端会连不上库）
MYSQL_DATABASE=agentpm
MYSQL_USER=agentpm
# 镜像版本，保持 latest；回滚时才改成历史标签（如 sha-1a2b3c4）
IMAGE_TAG=latest
# GitHub 用户名（镜像所在账号）。只有你 fork 到自己账号、用"方式一"下载镜像时才需要改成你的用户名；
# 用"方式二"本地构建、或直接用本仓库镜像的，都不用动。
IMAGE_OWNER=fangjinbao
