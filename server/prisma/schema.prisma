generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ==================== 基础系统模块 ====================

/// 系统用户
model SysUser {
  id           Int      @id @default(autoincrement())
  /// 所属部门 ID
  departmentId Int?
  /// 岗位 ID
  positionId   Int?
  /// 用户名（登录账号）
  username     String   @unique @db.VarChar(100)
  /// 工号
  workId       String?  @unique @db.VarChar(30)
  /// 密码（bcrypt 哈希，不对外返回）
  password     String
  /// 密码版本号（改密后旧 token 失效）
  passwordV    Int      @default(1)
  /// 姓名
  name         String?
  /// 昵称
  nickName     String?
  /// 头像 URL
  headImg      String?
  /// 手机号
  phone        String?  @db.VarChar(20)
  /// 邮箱
  email        String?
  /// 备注
  remark       String?
  /// 状态 1=启用 0=禁用
  status       Int      @default(1)
  /// 在线 socket 连接 ID（内部用，不对外返回）
  socketId     String?
  /// 租户 ID
  tenantId     Int?
  /// 创建时间
  createTime   DateTime @default(now())
  /// 更新时间
  updateTime   DateTime @updatedAt

  department SysDepartment? @relation(fields: [departmentId], references: [id])
  position   SysPosition?   @relation(fields: [positionId], references: [id])
  userRoles  SysUserRole[]

  @@index([departmentId])
  @@index([positionId])
  @@index([phone])
  @@index([tenantId])
  @@map("base_sys_user")
}

/// 系统角色
model SysRole {
  id         Int      @id @default(autoincrement())
  /// 角色名称
  name       String
  /// 角色标识（唯一）
  label      String?  @unique
  /// 备注
  remark     String?
  /// 数据权限范围标记
  relevance  Int      @default(1)
  /// 状态 1=启用 0=禁用
  status     Int      @default(1)
  /// 租户 ID
  tenantId   Int?
  /// 创建时间
  createTime DateTime @default(now())
  /// 更新时间
  updateTime DateTime @updatedAt

  userRoles       SysUserRole[]
  roleMenus       SysRoleMenu[]
  roleDepartments SysRoleDepartment[]

  @@index([tenantId])
  @@map("base_sys_role")
}

/// 系统菜单
model SysMenu {
  id         Int      @id @default(autoincrement())
  /// 父级菜单 ID
  parentId   Int?
  /// 菜单名称
  name       String
  /// 前端路由路径
  router     String?
  /// 权限标识
  perms      String?
  /// 类型 0=目录 1=菜单 2=按钮
  type       Int      @default(0)
  /// 图标
  icon       String?
  /// 排序号
  orderNum   Int      @default(0)
  /// 视图组件路径
  viewPath   String?
  /// 是否缓存 1=是 0=否
  keepAlive  Int      @default(1)
  /// 是否显示 1=是 0=否
  isShow     Int      @default(1)
  /// 租户 ID
  tenantId   Int?
  /// 创建时间
  createTime DateTime @default(now())
  /// 更新时间
  updateTime DateTime @updatedAt

  roleMenus SysRoleMenu[]

  @@index([parentId])
  @@index([tenantId])
  @@map("base_sys_menu")
}

/// 系统部门
model SysDepartment {
  id         Int      @id @default(autoincrement())
  /// 部门名称
  name       String
  /// 父级部门 ID
  parentId   Int?
  /// 部门类型
  type       String?  @db.VarChar(20)
  /// 负责人
  leader     String?  @db.VarChar(50)
  /// 联系电话
  phone      String?  @db.VarChar(20)
  /// 排序号
  orderNum   Int      @default(0)
  /// 状态 1=启用 0=禁用
  status     Int      @default(1)
  /// 租户 ID
  tenantId   Int?
  /// 创建时间
  createTime DateTime @default(now())
  /// 更新时间
  updateTime DateTime @updatedAt

  users           SysUser[]
  roleDepartments SysRoleDepartment[]

  @@index([parentId])
  @@index([tenantId])
  @@map("base_sys_department")
}

/// 用户-角色关联
model SysUserRole {
  id     Int @id @default(autoincrement())
  /// 用户 ID
  userId Int
  /// 角色 ID
  roleId Int

  user SysUser @relation(fields: [userId], references: [id], onDelete: Cascade)
  role SysRole @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@map("base_sys_user_role")
}

/// 角色-菜单关联
model SysRoleMenu {
  id     Int @id @default(autoincrement())
  /// 角色 ID
  roleId Int
  /// 菜单 ID
  menuId Int

  role SysRole @relation(fields: [roleId], references: [id], onDelete: Cascade)
  menu SysMenu @relation(fields: [menuId], references: [id], onDelete: Cascade)

  @@unique([roleId, menuId])
  @@map("base_sys_role_menu")
}

/// 角色-部门关联（数据权限）
model SysRoleDepartment {
  id           Int @id @default(autoincrement())
  /// 角色 ID
  roleId       Int
  /// 部门 ID
  departmentId Int

  role       SysRole       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  department SysDepartment @relation(fields: [departmentId], references: [id], onDelete: Cascade)

  @@unique([roleId, departmentId])
  @@map("base_sys_role_department")
}

/// 系统操作日志
model SysLog {
  id         Int      @id @default(autoincrement())
  /// 操作用户 ID
  userId     Int?
  /// 操作动作
  action     String?
  /// 请求 IP
  ip         String?  @db.VarChar(50)
  /// IP 归属地
  ipAddr     String?
  /// 请求参数
  params     String?  @db.Text
  /// 租户 ID
  tenantId   Int?
  /// 创建时间
  createTime DateTime @default(now())
  /// 更新时间
  updateTime DateTime @updatedAt

  @@index([userId])
  @@index([tenantId])
  @@map("base_sys_log")
}

/// 系统岗位
model SysPosition {
  id          Int      @id @default(autoincrement())
  /// 岗位名称
  name        String   @unique @db.VarChar(50)
  /// 岗位描述
  description String?  @db.VarChar(200)
  /// 排序号（升序）
  orderNum    Int      @default(0)
  /// 状态 1=启用 0=禁用
  status      Int      @default(1)
  /// 租户 ID
  tenantId    Int?
  /// 创建时间
  createTime  DateTime @default(now())
  /// 更新时间
  updateTime  DateTime @updatedAt

  users SysUser[]

  @@index([tenantId])
  @@map("base_sys_position")
}

/// 系统参数（键值对配置）
model SysParam {
  id         Int      @id @default(autoincrement())
  /// 参数键（唯一）
  keyName    String   @unique
  /// 参数名称
  name       String
  /// 参数值
  data       String?  @db.Text
  /// 备注
  remark     String?
  /// 租户 ID
  tenantId   Int?
  /// 创建时间
  createTime DateTime @default(now())
  /// 更新时间
  updateTime DateTime @updatedAt

  @@index([tenantId])
  @@map("base_sys_param")
}

// ==================== 字典模块 ====================

/// 字典类型
model DictType {
  id         Int      @id @default(autoincrement())
  /// 类型名称
  name       String
  /// 类型键（唯一）
  key        String   @unique
  /// 租户 ID
  tenantId   Int?
  /// 创建时间
  createTime DateTime @default(now())
  /// 更新时间
  updateTime DateTime @updatedAt

  items DictInfo[]

  @@index([tenantId])
  @@map("dict_type")
}

/// 字典项
model DictInfo {
  id         Int      @id @default(autoincrement())
  /// 所属字典类型 ID
  typeId     Int
  /// 字典项名称
  name       String
  /// 字典项值
  value      String
  /// 排序号
  orderNum   Int      @default(0)
  /// 状态 1=启用 0=停用
  status     Int      @default(1)
  /// 是否被业务引用（true 时禁止删除；原型阶段以字段标记，后续可改为按外键统计）
  referenced Boolean  @default(false)
  /// 备注
  remark     String?
  /// 租户 ID
  tenantId   Int?
  /// 创建时间
  createTime DateTime @default(now())
  /// 更新时间
  updateTime DateTime @updatedAt

  type DictType @relation(fields: [typeId], references: [id], onDelete: Cascade)

  @@index([typeId])
  @@index([tenantId])
  @@map("dict_info")
}

// ==================== 任务模块 ====================

/// 定时任务
model TaskInfo {
  id              Int       @id @default(autoincrement())
  /// 任务名称
  name            String
  /// cron 表达式
  cron            String?
  /// 固定间隔秒数
  every           Int?
  /// 执行次数限制
  limit           Int?
  /// 处理器标识
  service         String?
  /// 任务携带数据（JSON）
  data            String?
  /// 备注
  remark          String?
  /// 状态 1=运行 0=停止
  status          Int       @default(1)
  /// 类型
  type            Int       @default(0)
  /// 任务类型 0=cron 1=固定间隔
  taskType        Int       @default(0)
  /// 开始时间
  startDate       DateTime?
  /// 结束时间
  endDate         DateTime?
  /// 下次执行时间
  nextRunTime     DateTime?
  /// 上次执行时间
  lastExecuteTime DateTime?
  /// 租户 ID
  tenantId        Int?
  /// 创建时间
  createTime      DateTime  @default(now())
  /// 更新时间
  updateTime      DateTime  @updatedAt

  logs TaskLog[]

  @@index([tenantId])
  @@map("task_info")
}

/// 任务执行日志
model TaskLog {
  id         Int      @id @default(autoincrement())
  /// 所属任务 ID
  taskId     Int
  /// 执行状态 1=成功 0=失败
  status     Int      @default(0)
  /// 执行详情
  detail     String?  @db.Text
  /// 租户 ID
  tenantId   Int?
  /// 创建时间
  createTime DateTime @default(now())
  /// 更新时间
  updateTime DateTime @updatedAt

  task TaskInfo @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@index([tenantId])
  @@map("task_log")
}

// ==================== 文件模块 ====================

/// 文件信息
model SpaceInfo {
  id         Int      @id @default(autoincrement())
  /// 文件 URL
  url        String
  /// 文件类型（MIME）
  type       String?
  /// 分类 ID
  classifyId Int?
  /// 文件名
  name       String?
  /// 文件大小（字节）
  size       Int?
  /// 租户 ID
  tenantId   Int?
  /// 创建时间
  createTime DateTime @default(now())
  /// 更新时间
  updateTime DateTime @updatedAt

  @@index([classifyId])
  @@index([tenantId])
  @@map("space_info")
}

/// 文件分类
model SpaceType {
  id         Int      @id @default(autoincrement())
  /// 分类名称
  name       String
  /// 父分类 ID
  parentId   Int?
  /// 租户 ID
  tenantId   Int?
  /// 创建时间
  createTime DateTime @default(now())
  /// 更新时间
  updateTime DateTime @updatedAt

  @@index([tenantId])
  @@map("space_type")
}

// ==================== 插件模块 ====================

/// 插件信息
model PluginInfo {
  id          Int      @id @default(autoincrement())
  /// 插件名称
  name        String
  /// 插件键（唯一）
  keyName     String   @unique
  /// 钩子标识
  hook        String?
  /// 版本号
  version     String?
  /// 描述
  description String?
  /// 说明文档
  readme      String?  @db.Text
  /// Logo（base64 或 URL）
  logo        String?  @db.Text
  /// 作者
  author      String?
  /// 状态 1=启用 0=禁用
  status      Int      @default(0)
  /// 运行配置（JSON）
  config      Json?
  /// 插件元信息（JSON）
  pluginJson  Json?
  /// 租户 ID
  tenantId    Int?
  /// 创建时间
  createTime  DateTime @default(now())
  /// 更新时间
  updateTime  DateTime @updatedAt

  @@index([tenantId])
  @@map("plugin_info")
}

// ==================== 回收站模块 ====================

/// 回收站数据（软删快照）
model RecycleData {
  id         Int      @id @default(autoincrement())
  /// 实体名称
  entityName String
  /// 原记录 ID
  entityId   Int
  /// 原记录数据快照（JSON）
  data       Json
  /// 操作人 ID
  userId     Int?
  /// 租户 ID
  tenantId   Int?
  /// 创建时间
  createTime DateTime @default(now())
  /// 更新时间
  updateTime DateTime @updatedAt

  @@index([entityName, entityId])
  @@index([tenantId])
  @@map("recycle_data")
}

// ==================== 系统配置 - 业务基础数据 ====================

/// 问题类型（整改工单问题分类，SRS 3.5.9.2 / LLD 4.3.16）
model IssueType {
  id         Int      @id @default(autoincrement())
  /// 类型名称
  name       String   @db.VarChar(50)
  /// 默认审核人 ID（关联 base_sys_user.id，可空）
  auditorId  Int?
  /// 排序号（升序，数字越小越靠前）
  orderNum   Int      @default(0)
  /// 状态 1=启用 0=停用（停用后工单提交不可选）
  status     Int      @default(1)
  /// 租户 ID
  tenantId   Int?
  /// 创建时间
  createTime DateTime @default(now())
  /// 更新时间
  updateTime DateTime @updatedAt

  @@index([auditorId])
  @@index([tenantId])
  @@map("biz_issue_type")
}

// ==================== 系统管理模块 ====================

/// 系统参数配置（业务可调参数，区别于 base_sys_param 的系统级 KV 配置）
model SysParamConfig {
  id          Int      @id @default(autoincrement())
  /// 参数名称
  name        String   @db.VarChar(100)
  /// 参数值（统一以字符串存储，按 valueType 解释）
  value       String   @db.Text
  /// 参数说明
  description String?  @db.VarChar(500)
  /// 参数值类型，如 int
  valueType   String   @default("int") @db.VarChar(20)
  /// 允许最小值（int 类型时生效，可空）
  minValue    Int?
  /// 允许最大值（int 类型时生效，可空）
  maxValue    Int?
  /// 租户 ID
  tenantId    Int?
  /// 创建时间
  createTime  DateTime @default(now())
  /// 更新时间
  updateTime  DateTime @updatedAt

  @@index([tenantId])
  @@map("sys_param_config")
}

/// AI 模型配置（apiKey 为敏感字段，接口下发时脱敏，不返回完整密钥）
model SysAiModel {
  id         Int      @id @default(autoincrement())
  /// 配置名称（全局唯一）
  name       String   @unique @db.VarChar(100)
  /// 模型服务商：OpenAI / Anthropic
  provider   String   @db.VarChar(50)
  /// 模型名称
  model      String   @db.VarChar(100)
  /// 接口地址（base url，如 https://api.openai.com/v1）
  apiUrl     String   @db.VarChar(500)
  /// 接口密钥（敏感，仅存储，不下发完整值）
  apiKey     String   @db.VarChar(500)
  /// 启用状态 1=启用 0=停用（全局仅一项启用）
  status     Int      @default(0)
  /// 连接状态：normal 正常 / error 异常 / unknown 未测试
  connStatus String   @default("unknown") @db.VarChar(20)
  /// 租户 ID
  tenantId   Int?
  /// 创建时间
  createTime DateTime @default(now())
  /// 更新时间
  updateTime DateTime @updatedAt

  @@index([tenantId])
  @@map("sys_ai_model")
}

/// 系统操作日志（仅查看，记录操作人行为审计）
model SysOperationLog {
  id          Int      @id @default(autoincrement())
  /// 操作人姓名
  operator    String   @db.VarChar(50)
  /// 操作类型：新增/编辑/删除/登录/其他
  type        String   @db.VarChar(20)
  /// 操作对象（如"题目管理"）
  target      String   @db.VarChar(100)
  /// 操作内容描述
  content     String   @db.VarChar(500)
  /// 来源网络地址
  sourceIp    String   @db.VarChar(50)
  /// 操作时间
  operateTime DateTime @default(now())
  /// 租户 ID
  tenantId    Int?
  /// 创建时间
  createTime  DateTime @default(now())
  /// 更新时间
  updateTime  DateTime @updatedAt

  @@index([operator])
  @@index([type])
  @@index([operateTime])
  @@index([tenantId])
  @@map("sys_operation_log")
}

// ==================== 考试域模块 ====================

/// 外部单位（外部考生的归属组织，为外部考生录入提供可选单位范围；被外部考生引用时不可删除）
model ExternalOrg {
  id         Int      @id @default(autoincrement())
  /// 单位名称（系统内全局唯一）
  name       String   @unique @db.VarChar(100)
  /// 单位编码（系统内全局唯一，可空）
  code       String?  @unique @db.VarChar(30)
  /// 联系人（可空）
  contact    String?  @db.VarChar(50)
  /// 联系电话（手机号，可空）
  phone      String?  @db.VarChar(20)
  /// 单位地址（可空）
  address    String?  @db.VarChar(200)
  /// 备注（可空）
  remark     String?  @db.VarChar(200)
  /// 状态 1=启用 0=停用（停用后不可被外部考生选择）
  status     Int      @default(1)
  /// 租户 ID
  tenantId   Int?
  /// 创建时间
  createTime DateTime @default(now())
  /// 更新时间
  updateTime DateTime @updatedAt

  /// 归属本单位的外部考生（反向关系）
  candidates ExternalCandidate[]

  @@index([tenantId])
  @@map("exam_external_org")
}

/// 外部考生（外部单位参加考试人员，由系统生成考试账号；password/passwordV 为敏感字段，不对外返回）
model ExternalCandidate {
  id         Int      @id @default(autoincrement())
  /// 姓名
  name       String   @db.VarChar(50)
  /// 所属外部单位 ID（必填，指向已启用的 ExternalOrg）
  orgId      Int
  /// 证件号（用于身份核验，可空）
  idCard     String?  @db.VarChar(30)
  /// 联系电话（手机号，同时作为考试账号登录名，系统内全局唯一）
  phone      String   @unique @db.VarChar(20)
  /// 电子邮箱（可空）
  email      String?  @db.VarChar(50)
  /// 考试账号密码（bcrypt 哈希，敏感，不对外返回）
  password   String
  /// 密码版本号（重置密码后自增，使旧登录态失效，敏感，不对外返回）
  passwordV  Int      @default(1)
  /// 账号状态 1=启用 0=停用（停用后不可登录考生端）
  status     Int      @default(1)
  /// 租户 ID
  tenantId   Int?
  /// 创建时间
  createTime DateTime @default(now())
  /// 更新时间
  updateTime DateTime @updatedAt

  /// 所属外部单位（多对一）
  org ExternalOrg @relation(fields: [orgId], references: [id])

  @@index([orgId])
  @@index([tenantId])
  @@map("exam_external_candidate")
}

/// 考点（考试场地基础信息，供考试管理进行考点安排；被考试引用时不可删除）
model ExamSite {
  id         Int      @id @default(autoincrement())
  /// 考点名称（系统内唯一）
  name       String   @unique @db.VarChar(50)
  /// 考点地址
  address    String   @db.VarChar(200)
  /// 容纳人数（可空，正整数）
  capacity   Int?
  /// 联系人（可空）
  contact    String?  @db.VarChar(50)
  /// 联系电话（可空，11 位手机号）
  phone      String?  @db.VarChar(11)
  /// 状态 1=启用 0=停用
  status     Int      @default(1)
  /// 租户 ID
  tenantId   Int?
  /// 创建时间
  createTime DateTime @default(now())
  /// 更新时间
  updateTime DateTime @updatedAt

  @@index([tenantId])
  @@map("exam_site")
}

/// 知识点分类（题库分类体系，树形结构；被题目引用或存在子节点时不可删除）
model KnowledgePoint {
  id         Int      @id @default(autoincrement())
  /// 父级知识点 ID（顶级节点为 null）
  parentId   Int?
  /// 知识点名称
  name       String   @db.VarChar(100)
  /// 排序号（同级内升序）
  orderNum   Int      @default(0)
  /// 备注
  remark     String?  @db.VarChar(200)
  /// 租户 ID
  tenantId   Int?
  /// 创建时间
  createTime DateTime @default(now())
  /// 更新时间
  updateTime DateTime @updatedAt

  /// 关联的题目（一对多）
  questions Question[]

  @@index([parentId])
  @@index([tenantId])
  @@map("exam_knowledge_point")
}

/// 题目（题库核心数据；题型/难度存数据字典的 value，知识点关联知识点分类；状态区分正式/待审）
model Question {
  id               Int      @id @default(autoincrement())
  /// 题干（多行文本）
  stem             String   @db.Text
  /// 题型（存字典 question_type 的 value：single 单选/multiple 多选/judge 判断/blank 填空/qa 问答/essay 论述）
  type             String   @db.VarChar(20)
  /// 选项（多行文本；客观题 single/multiple/judge/blank 必填，主观题 qa/essay 为空）
  options          String?  @db.Text
  /// 标准答案
  answer           String   @db.Text
  /// 答案解析（可空）
  analysis         String?  @db.Text
  /// 难度（存字典 difficulty 的 value：easy 简单/medium 中等/hard 困难）
  difficulty       String   @db.VarChar(20)
  /// 所属知识点 ID（指向 KnowledgePoint）
  knowledgePointId Int
  /// 所属题库 ID（指向 QuestionBank，可空以兼容存量题目；新题目应归属题库）
  questionBankId   Int?
  /// 分值建议（可空，正整数）
  suggestedScore   Int?
  /// 状态：formal 正式 / pending 待审（AI 生成题目审核通过前保持 pending）
  status           String   @default("formal") @db.VarChar(20)
  /// 退回原因（审核退回时记录，≤200 字）
  rejectReason     String?  @db.VarChar(200)
  /// 租户 ID
  tenantId         Int?
  /// 创建时间
  createTime       DateTime @default(now())
  /// 更新时间
  updateTime       DateTime @updatedAt

  /// 所属知识点（多对一）
  knowledgePoint KnowledgePoint @relation(fields: [knowledgePointId], references: [id])
  /// 所属题库（多对一，可空）
  questionBank   QuestionBank?  @relation(fields: [questionBankId], references: [id])

  @@index([knowledgePointId])
  @@index([questionBankId])
  @@index([type])
  @@index([difficulty])
  @@index([status])
  @@index([tenantId])
  @@map("exam_question")
}

/// 题库（题目容器，按业务主题划分，如"安全教育题库"；先建题库再进入维护其题目）
model QuestionBank {
  id          Int      @id @default(autoincrement())
  /// 题库名称（2-50 字，全局唯一）
  name        String   @unique @db.VarChar(50)
  /// 题库编码（≤30 字，全局唯一；新增留空时由系统自动生成）
  code        String   @unique @db.VarChar(30)
  /// 题库描述（≤200 字，可空）
  description String?  @db.VarChar(200)
  /// 状态 1=启用 0=停用（停用后组卷/抽题/练习不展示，历史引用不受影响）
  status      Int      @default(1)
  /// 租户 ID
  tenantId    Int?
  /// 创建时间
  createTime  DateTime @default(now())
  /// 更新时间
  updateTime  DateTime @updatedAt

  /// 本题库下的题目（一对多，反向关系）
  questions Question[]

  @@index([tenantId])
  @@map("exam_question_bank")
}
